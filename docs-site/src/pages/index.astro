---
import '../styles/landing.css';
const base = import.meta.env.BASE_URL; // '/calit/'
const docs = `${base}introduction/quick-start/`;
const features = '#features';
const gallery = '#gallery';
const repo = 'https://github.com/asm0dey/calit';
const privacy = `${base}privacy/`;
const img = (name) => `${base}img/${name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>calit — scheduling you own</title>
    <link rel="icon" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="lp-body">
    <div class="lp">
      <header class="lp-wrap lp-nav lp-rise lp-d1">
        <a class="lp-brand" href={base}><span class="chip">c</span> calit</a>
        <nav class="lp-nav-right">
          <a class="lp-navlink hide-sm" href={gallery}>Product</a>
          <a class="lp-navlink hide-sm" href={features}>Features</a>
          <a class="lp-navlink" href={repo}>GitHub</a>
          <a class="lp-btn lp-btn-primary" href={docs}>Read the docs <span class="arr">&rarr;</span></a>
        </nav>
      </header>

      <section class="lp-wrap lp-hero">
        <span class="lp-eyebrow lp-rise lp-d1">Self-hosted &middot; Open source &middot; Multi-user</span>
        <h1 class="lp-rise lp-d2">The scheduling app you <em>actually own</em>.</h1>
        <p class="lp-sub lp-rise lp-d3">calit gives every user their own scheduling space &mdash; a personal booking page, availability,
          and Google Calendar &mdash; running entirely on <strong>your</strong> server. No SaaS, no per-seat pricing, no lock-in.</p>
        <div class="lp-cta lp-rise lp-d3">
          <a class="lp-btn lp-btn-primary" href={docs}>Get started <span class="arr">&rarr;</span></a>
          <a class="lp-btn lp-btn-ghost" href={gallery}>See it in action</a>
        </div>
        <div class="lp-trust lp-rise lp-d4">
          <span>argon2id auth</span><span>Google Meet links</span><span>approval flows</span><span>one binary + Postgres</span>
        </div>

        <div class="lp-shot-wrap lp-rise lp-d5">
          <div class="lp-frame">
            <div class="bar"><i></i><i></i><i></i><span class="url">yourteam.com/alex/intro-call</span></div>
            <img src={img('product-booking.png')} alt="calit booking page: a monthly calendar of available days beside a column of bookable time slots" width="1440" height="960" />
          </div>
        </div>
      </section>

      <section id="gallery" class="lp-dark">
        <div class="lp-wrap">
          <div class="lp-head">
            <span class="lp-eyebrow">A look inside</span>
            <h2>One app. Three surfaces.</h2>
            <p class="lp-lede">A public page for invitees, a personal landing for every user, and an owner console to run it all &mdash;
              each isolated to its owner, served from the same self-hosted instance.</p>
          </div>

          <div class="lp-gallery">
            <div class="lp-card">
              <div class="lp-frame">
                <div class="bar"><i></i><i></i><i></i><span class="url">yourteam.com/me</span></div>
                <img src={img('product-dashboard.png')} loading="lazy" alt="calit owner dashboard showing upcoming bookings and a side navigation" width="1440" height="960" />
              </div>
              <div class="lp-cap"><b>The owner console</b><span>Manage meeting types, availability, booking fields, Google sync, and &mdash; for admins &mdash; the whole team's users at <code>/me</code>.</span></div>
            </div>
            <div class="lp-stackcol">
              <div class="lp-card">
                <div class="lp-frame">
                  <div class="bar"><i></i><i></i><i></i><span class="url">yourteam.com/alex</span></div>
                  <img src={img('product-landing.png')} loading="lazy" alt="A user's public landing page listing their bookable meeting types" width="1440" height="960" />
                </div>
                <div class="lp-cap"><b>Each user's landing</b><span>Every user gets <code>/their-name</code> &mdash; their own active meeting types, nobody else's.</span></div>
              </div>
              <div class="lp-card">
                <div class="lp-frame">
                  <div class="bar"><i></i><i></i><i></i><span class="url">&hellip;/intro-call &middot; booked</span></div>
                  <img src={img('product-confirmation.png')} loading="lazy" alt="Booking confirmation screen shown to the invitee after they pick a time" width="1440" height="960" />
                </div>
                <div class="lp-cap"><b>Confirmed in a tap</b><span>Invitees pick a slot in their own timezone; both sides get an email and a Meet link.</span></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="lp-wrap lp-feat">
        <span class="lp-eyebrow">Why calit</span>
        <h2>Built to be run, not rented.</h2>
        <p class="lp-lede">Everything you expect from a scheduling tool &mdash; plus true multi-tenancy and the peace of mind of owning your data.</p>

        <div class="lp-grid">
          <div class="lp-cell"><div class="k">Isolation</div><h3>Per-user tenancy</h3><p>Every meeting type, booking, and setting carries an owner. One user can never see or touch another's data.</p></div>
          <div class="lp-cell"><div class="k">Calendar</div><h3>Google sync &amp; Meet</h3><p>Connect each user's own Google account. Bookings create events and auto-generate a Meet link &mdash; or run fully degraded.</p></div>
          <div class="lp-cell"><div class="k">Control</div><h3>Approvals &amp; limits</h3><p>Hold meetings as pending until approved, with per-type buffers, minimum notice, and a booking horizon.</p></div>
          <div class="lp-cell"><div class="k">Trust</div><h3>Real authentication</h3><p>Passwords hashed with argon2id, stateless encrypted cookies, instant lockout &mdash; no embedded admin password.</p></div>
          <div class="lp-cell"><div class="k">Defense</div><h3>Abuse protection</h3><p>Cloudflare Turnstile, a honeypot, and a per-email daily cap guard every public booking form out of the box.</p></div>
          <div class="lp-cell"><div class="k">Ops</div><h3>One binary + Postgres</h3><p>A single Quarkus app and a database. Self-host it anywhere, invite your team, done. Opt-in public sign-up too.</p></div>
        </div>
      </section>

      <section class="lp-wrap lp-close">
        <div class="panel">
          <span class="lp-eyebrow" style="justify-content:center;color:var(--indigo-3)">Get started</span>
          <h2>Spin up your own in minutes.</h2>
          <p>Point it at a Postgres database and open the site &mdash; the first visit creates your admin account. No license, no waitlist, no seat math.</p>
          <div class="codeline"><span class="p">$</span> docker compose up <span class="p">&middot;</span> visit <span style="color:var(--paper-on-dark)">/setup</span></div>
          <div class="lp-cta" style="justify-content:center;margin-top:28px">
            <a class="lp-btn lp-btn-primary" href={docs}>Read the docs <span class="arr">&rarr;</span></a>
            <a class="lp-btn lp-btn-ghost" style="color:var(--paper-on-dark);border-color:rgba(255,255,255,.18)" href={features}>Explore features</a>
          </div>
        </div>
      </section>

      <footer class="lp-wrap lp-foot">
        <a class="lp-brand" href={base}><span class="chip">c</span> calit</a>
        <span class="meta">Self-hosted scheduling &middot; your data never leaves your server</span>
        <a class="lp-navlink" href={privacy}>Privacy</a>
      </footer>
    </div>
  </body>
</html>
